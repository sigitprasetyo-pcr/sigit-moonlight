<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:paddingHorizontal="36dp"
    android:paddingBottom="24dp">

    <!-- Glowing Icon Container -->
    <FrameLayout
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_marginBottom="40dp">

        <!-- Outer soft glow ring -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0.12"
            android:background="@drawable/bg_circle_icon_blue" />

        <!-- Mid ring -->
        <View
            android:layout_width="168dp"
            android:layout_height="168dp"
            android:layout_gravity="center"
            android:alpha="0.20"
            android:background="@drawable/bg_circle_icon_blue" />

        <!-- Inner icon circle -->
        <FrameLayout
            android:layout_width="130dp"
            android:layout_height="130dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_onboarding_circle">

            <ImageView
                android:id="@+id/ivOnboarding"
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:layout_gravity="center"
                app:srcCompat="@drawable/ic_onboarding_welcome"
                app:tint="#FFFFFF" />
        </FrameLayout>
    </FrameLayout>

    <!-- Gold line accent -->
    <View
        android:layout_width="48dp"
        android:layout_height="3dp"
        android:background="#D4A017"
        android:layout_marginBottom="20dp" />

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Selamat Datang"
        android:textAlignment="center"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="16dp" />

    <!-- Description -->
    <TextView
        android:id="@+id/tvDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Deskripsi fitur aplikasi"
        android:textAlignment="center"
        android:textColor="#90B8D8"
        android:textSize="15sp"
        android:lineSpacingExtra="5dp" />

</LinearLayout>