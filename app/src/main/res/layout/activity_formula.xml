<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".pertemuan_2.FormulaActivity">

    <!-- Toolbar diturunkan dengan height lebih besar dan padding top -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:paddingTop="30dp"
        android:background="@color/white"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:title="Rumus Bangun"
        app:titleTextColor="@color/text_main" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvTitleFormula"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rumus Bangun"
                android:textSize="22sp"
                android:textColor="@color/text_main"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDescFormula"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Deskripsi halaman"
                android:textColor="@color/text_secondary" />

            <!-- Luas Segitiga Section -->
            <TextView
                android:id="@+id/tvLabelSegitiga"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="1. Luas Segitiga (Bangun Datar)"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/etAlas"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Alas"
                    android:inputType="numberDecimal" />

                <EditText
                    android:id="@+id/etTinggi"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:hint="Tinggi"
                    android:inputType="numberDecimal" />
            </LinearLayout>

            <Button
                android:id="@+id/btnHitungSegitiga"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Hitung Luas Segitiga" />

            <TextView
                android:id="@+id/tvHasilSegitiga"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Hasil: -"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/primaryColor"/>

            <!-- Volume Kubus Section -->
            <TextView
                android:id="@+id/tvLabelKubus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="2. Volume Kubus (Bangun Ruang)"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etSisi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Masukkan Sisi"
                android:inputType="numberDecimal" />

            <Button
                android:id="@+id/btnHitungKubus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Hitung Volume Kubus" />

            <TextView
                android:id="@+id/tvHasilKubus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Hasil: -"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/primaryColor"
                android:layout_marginBottom="40dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>