<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white"
    app:strokeColor="@color/outline_variant"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Left Accent Line (will be tinted dynamically) -->
        <View
            android:id="@+id/leftAccent"
            android:layout_width="5dp"
            android:layout_height="0dp"
            android:background="@color/text_muted"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Content Container -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:padding="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/leftAccent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Status Chip -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_pending_chip"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="Menunggu"
                android:textColor="@color/text_muted"
                android:textSize="10sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Title -->
            <TextView
                android:id="@+id/tvJudul"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:text="Judul Aspirasi"
                android:textColor="@color/primary_dark"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@id/tvStatus"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Sender and Date -->
            <TextView
                android:id="@+id/tvPengirim"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Oleh: Budi"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvJudul" />

            <TextView
                android:id="@+id/tvTanggal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="14 Juni 2026"
                android:textColor="@color/text_muted"
                android:textSize="11sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvPengirim" />

            <!-- Short description snippet -->
            <TextView
                android:id="@+id/tvIsiSnippet"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:text="Isi aspirasi..."
                android:textColor="#334155"
                android:textSize="13sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvTanggal" />

            <!-- Detail Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDetailAspirasi"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_button_gradient"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingHorizontal="20dp"
                android:text="Lihat Detail"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                app:backgroundTint="@null"
                app:cornerRadius="8dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvIsiSnippet" />

            <!-- Edit Action Button inside soft blue circle -->
            <ImageButton
                android:id="@+id/btnEditAspirasi"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_circle_edit"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="@color/secondary"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/btnDeleteAspirasi"
                app:layout_constraintTop_toBottomOf="@id/tvIsiSnippet" />

            <!-- Delete Action Button inside soft red circle -->
            <ImageButton
                android:id="@+id/btnDeleteAspirasi"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_circle_delete"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:src="@android:drawable/ic_menu_delete"
                app:tint="@color/error"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvIsiSnippet" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
