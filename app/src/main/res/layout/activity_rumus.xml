<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".pertemuan_4.rumus.RumusActivity">

    <!-- Navbar/Toolbar diturunkan agar tidak tertutup notch -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:paddingTop="32dp"
        android:background="@color/white"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:title="Rumus Bangun"
        app:titleTextColor="@color/text_main" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Kubus Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Perhitungan Kubus"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/text_main"/>

            <EditText
                android:id="@+id/etSisi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Masukkan Sisi"
                android:inputType="numberDecimal"
                android:layout_marginTop="8dp"/>

            <Button
                android:id="@+id/btnHitungLuasKubus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hitung Luas Kubus"
                android:layout_marginTop="8dp"/>

            <Button
                android:id="@+id/btnHitungVolumeKubus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hitung Volume Kubus"
                android:layout_marginTop="4dp"/>

            <!-- Segitiga Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Perhitungan Segitiga"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginTop="24dp"
                android:textColor="@color/text_main"/>

            <EditText
                android:id="@+id/etAlas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Alas"
                android:inputType="numberDecimal"
                android:layout_marginTop="8dp"/>

            <EditText
                android:id="@+id/etTinggi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Tinggi"
                android:inputType="numberDecimal"
                android:layout_marginTop="4dp"/>

            <Button
                android:id="@+id/btnHitungLuasSegitiga"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hitung Luas Segitiga"
                android:layout_marginTop="8dp"/>

            <!-- Hasil -->
            <TextView
                android:id="@+id/tvHasil"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hasil: -"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                android:textColor="@color/primaryColor"/>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>